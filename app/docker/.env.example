# Copy to .env on the intranet server and replace every secret before testing.
MYSQL_ROOT_PASSWORD=replace-with-strong-mysql-root-password
MYSQL_DATABASE=im_db
MYSQL_PORT=3306

REDIS_PORT=6379

BACKEND_PORT=8080
NGINX_PORT=80

JWT_SECRET=replace-with-at-least-32-random-characters

# Keep local until MinIO health, policy and migration checks pass.
FILE_STORAGE=local
LOCAL_UPLOAD_PATH=/opt/im-project/huiyu/data/upload

# MinIO Community is built from the pinned source commit in Dockerfile.minio.
MINIO_DATA_PATH=/opt/minio/data
MINIO_CONSOLE_BIND_IP=172.16.59.253
MINIO_BUCKET=im-files
MINIO_ROOT_USER=minio-root
MINIO_ROOT_PASSWORD=replace-with-48-random-hex-characters
MINIO_ACCESS_KEY=im-backend
MINIO_SECRET_KEY=replace-with-48-random-hex-characters
